{
    "tabWidth": 4,
    "printWidth": 100,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "overrides": [
        {
            "files": ["src/frontend/**/*.tsx", "src/frontend/**/*.ts"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
